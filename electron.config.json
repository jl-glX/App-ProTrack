{
  "name": "Budget Tracker",
  "productName": "Budget Tracker",
  "version": "1.0.0",
  "description": "Smart budget tracking and expense management application",
  "main": "electron-main.js",
  "author": "Budget Tracker Team",
  "license": "MIT",
  "build": {
    "appId": "com.budgettracker.app",
    "directories": {
      "buildResources": "build",
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": ["dmg", "zip"],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm", "snap"],
      "category": "Office;Finance",
      "icon": "build/icons"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
