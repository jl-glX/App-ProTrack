{
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Server (tsx)",
            "program": "${workspaceFolder}/server/index.ts",
            "runtimeArgs": [
                "--trace-warnings",
                "--trace-uncaught",
                "--import",
                "tsx"
            ],
            "cwd": "${workspaceFolder}",
            "internalConsoleOptions": "neverOpen"
        }
    ]
}
